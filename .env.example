# Copy this file to .env and fill in your values.
# For the Vercel + Cloudflare Tunnel deployment, see deploy/RUNBOOK.md.

# ── Database ──────────────────────────────────────────────────────────────────
# Local SQLite (Vercel + Cloudflare Tunnel deployment):
DATABASE_URL=sqlite:///research_platform.db
# PostgreSQL (future, if migrating off SQLite):
# DATABASE_URL=postgresql://user:password@localhost:5432/research_platform

# ── LLM provider ─────────────────────────────────────────────────────────────
# Supported: anthropic, gemini
LLM_PROVIDER=anthropic

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=<key-issued-by-proxy>
# Internal company proxy — only reachable on the corporate office network.
# Leave blank to hit api.anthropic.com directly (required when off-network).
ANTHROPIC_BASE_URL=https://clear-llm-proxy.internal.cleartax.co

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=gemini
GEMINI_API_KEY=<your-gemini-api-key>

# ── CORS ──────────────────────────────────────────────────────────────────────
# The exact origin the browser sends — protocol + host, no trailing slash.
# Dev default (any localhost port) is always allowed automatically.
# Set this to your Vercel deployment URL for production.
# Example: CORS_ORIGIN=https://your-project.vercel.app
CORS_ORIGIN=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Baked into the Next.js client bundle at build time.
# Set to your Cloudflare Tunnel API URL for production builds.
# Example: NEXT_PUBLIC_API_URL=https://api.your-tunnel-domain.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Semantic search ───────────────────────────────────────────────────────────
SEMANTIC_SEARCH=true
